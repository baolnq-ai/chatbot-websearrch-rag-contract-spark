# ==============================================================================
# RAG Chatbot - Root Environment Example
# Sao chép thành `.env` ở thư mục gốc và điền secret thật khi triển khai.
# Không tạo `.env` riêng trong backend/embedding/parse-data/prometheus-collector.
# Frontend có thể giữ `frontend/.env.local` riêng.
# ==============================================================================

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=6102
TRUSTED_PROXY_IPS=127.0.0.1,::1,172.16.0.0/12

# --- Public URLs ---
BACKEND_URL=http://localhost:6101/api/v1
FRONTEND_URL=http://localhost:6101
NEXT_PUBLIC_API_URL=/
NEXT_PUBLIC_APP_URL=http://localhost:6101
CORS_ALLOW_ORIGINS=http://localhost:6101,http://localhost:6103

# --- Nginx reverse proxy / Cloudflare Tunnel entrypoint ---
NGINX_PUBLIC_PORT=6101
NGINX_FRONTEND_UPSTREAM=host.docker.internal:6103
NGINX_BACKEND_UPSTREAM=host.docker.internal:6102
NGINX_CLIENT_MAX_BODY_SIZE=50m
NGINX_PROXY_READ_TIMEOUT=3600s
NGINX_PROXY_SEND_TIMEOUT=3600s

# --- Parser service ---
MARKER_URL=http://127.0.0.1:6104/api/v1/parse
PARSER_SERVER_HOST=0.0.0.0
PARSER_SERVER_PORT=6104
PARSER_SERVER_RELOAD=true
PARSER_HOST_PORT=6104

# --- Embedding / rerank service ---
BGE_BASE_URL=http://127.0.0.1:6105
BGE_EMBED_PATH=/api/v1/embed
BGE_RERANK_PATH=/api/v1/rerank
EMBEDDING_SERVER_HOST=0.0.0.0
EMBEDDING_SERVER_PORT=6105
EMBEDDING_SERVER_RELOAD=false
EMBEDDING_HOST_PORT=6105

# --- Web Search ---
SEARXNG_BASE_URL=http://127.0.0.1:6121
SEARXNG_SECRET=change_me
SEARXNG_ENGINES=google,bing,duckduckgo
SEARXNG_BIND_ADDR=127.0.0.1
SEARXNG_REDIS_URL=redis://:change_me@redis:6379/1
WEB_SEARXNG_TOPK=30
WEB_SEARCH_TIMEOUT_SEC=8
WEB_FETCH_TIMEOUT_SEC=8
WEB_FETCH_MAX_CONCURRENCY=6
WEB_FETCH_RETRY_MAX=2
WEB_FETCH_RETRY_BASE_MS=200
WEB_MAX_URLS_PER_QUERY=5
WEB_MAX_CANDIDATE_URLS=50
WEB_URL_SELECTOR_PREFETCH_MULTIPLIER=4
WEB_TITLE_FETCH_TIMEOUT_SEC=4
WEB_LISTING_EXPAND_MAX_PAGES=3
WEB_LISTING_EXPAND_LINK_LIMIT=20
WEB_MAX_CONTENT_CHARS_PER_URL=6000
WEB_MIN_CONTENT_CHARS_PER_URL=140
WEB_MAX_TOTAL_WEB_CONTEXT=24000
WEB_DOMAIN_MAP_TTL_SEC=1800
WEB_SEARCH_LOG_ENABLED=false
WEB_QUERY_DECOMPOSITION_ENABLED=true
WEB_QUERY_DECOMPOSITION_MAX_SUBQUERIES=6
WEB_QUERY_PLANNER_LLM_ENABLED=true
WEB_BROAD_SEARCH_ENABLED=true
WEB_SEARCH_STRICT_SOURCE_FILTER=false
WEB_SEARCH_ALLOWED_DOMAINS=
WEB_SEARCH_BLOCKED_DOMAINS=
WEB_SEARCH_ALLOWED_URL_PREFIXES=
WEB_SEARCH_BLOCKED_URL_PREFIXES=
WEB_ADAPTIVE_BUDGET_ENABLED=true
WEB_ADAPTIVE_LOW_RERANK_THRESHOLD=0.62
WEB_ADAPTIVE_EXTRA_FETCH_URLS=3
WEB_MAX_EVIDENCE_PER_DOMAIN=2
WEB_CITATION_VALIDATION_ENABLED=true
WEB_EVIDENCE_SUMMARIZER_ENABLED=true
WEB_SUMMARIZER_MIN_SCORE=0.48
WEB_SEARCH_EVALUATOR_LOOP_ENABLED=true
WEB_SEARCH_MAX_RESEARCH_LOOPS=2
WEB_EVALUATOR_MIN_EVIDENCE=3
WEB_EVALUATOR_MIN_DOMAINS=2
WEB_EVALUATOR_MIN_TOP_SCORE=0.65
WEB_SEARCH_BROKER_ENABLED=true
WEB_SEARCH_PROVIDER_PRIORITY=brave,bing,searxng
WEB_SEARCH_GLOBAL_CONCURRENCY=8
WEB_SEARCH_GLOBAL_RPS=6
WEB_SEARCH_RETRY_MAX=2
WEB_SEARCH_RETRY_BASE_MS=200
WEB_SEARCH_CB_FAIL_THRESHOLD=5
WEB_SEARCH_CB_OPEN_SEC=60
WEB_SEARCH_CACHE_TTL_SEC=600
WEB_SEARCH_GLOBAL_RATE_LIMIT_PER_MIN=300
WEB_SEARCH_EGRESS_PROXY_URL=
WEB_FETCH_EGRESS_PROXY_URL=
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com
BING_SEARCH_API_KEY=
BING_SEARCH_BASE_URL=https://api.bing.microsoft.com/v7.0

# --- PostgreSQL ---
POSTGRES_USER=bao
POSTGRES_PASSWORD=change_me
POSTGRES_DB=multiangent_db
SQLALCHEMY_DATABASE_URL=postgresql+asyncpg://bao:change_me@127.0.0.1:6111/multiangent_db
POSTGRES_HOST_PORT=6110
PGBOUNCER_HOST_PORT=6111
ADMINER_HOST_PORT=6112
POSTGRES_EXPORTER_HOST_PORT=6122

# --- Qdrant ---
QDRANT_URL=http://127.0.0.1:6113
QDRANT_COLLECTION_NAME=rag_data
QDRANT_VECTOR_SIZE=2048
QDRANT_HOST_PORT=6113

# --- MinIO ---
MINIO_ENDPOINT=127.0.0.1:6114
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
MINIO_SECURE=false
MINIO_BUCKET=contract-templates
MINIO_CONTRACT_BUCKET=contracts
MINIO_RAW_BUCKET=raw-files
MINIO_API_HOST_PORT=6114
MINIO_CONSOLE_HOST_PORT=6115

# --- vLLM ---
VLLM_BASE_URL=http://127.0.0.1:6106/v1
VLLM_MODEL_NAME=google/gemma-4-E4B-it
VLLM_MODELS_LIST=google/gemma-4-E4B-it
VLLM_CONTAINER_NAME=vllm_gemma4
VLLM_IMAGE=local/vllm-openai-gemma4:latest
VLLM_HOST_PORT=6106
VLLM_SHM_SIZE=16g
GPU_MEMORY_UTIL=0.30
VLLM_KV_CACHE_MEMORY_BYTES=2147483648
HF_CACHE_MOUNT=./cache/huggingface
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# --- LLM and RAG budgets ---
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=3600
LLM_CONTEXT_WINDOW=8192
RAG_INPUT_TOKEN_BUDGET=6144
RAG_OUTPUT_TOKEN_BUDGET=2048
RAG_FILE_CONTEXT_TOKEN_BUDGET=4096
RAG_HISTORY_TOKEN_BUDGET=1024
RAG_SELECTED_PATH_TOKEN_BUDGET=6144
RAG_AVG_TOKENS_PER_CHUNK=600
RAG_CHARS_PER_TOKEN=2.5

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6116
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@127.0.0.1:6116/0
REDIS_HOST_PORT=6116
REDIS_INSIGHT_HOST_PORT=6117
REDIS_EXPORTER_HOST_PORT=6123

# --- Auth ---
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
VERIFY_TOKEN_EXPIRE_MINUTES=60
VERIFY_TOKEN_PEPPER=

# --- App config ---
RAG_UPLOAD_MAX_SIZE_MB=10
ROOT_EMAIL=admin@example.com
ROOT_PASSWORD=change_me
FOLDER_PATH_CONTRACT=database/storage/contract
FOLDER_PATH_TEMPLATE=database/storage/template
GEOIP_DIR=database/geoip

# --- Prometheus collector ---
PROMETHEUS_URL=http://127.0.0.1:6118
PROMETHEUS_COLLECTOR_URL=http://127.0.0.1:6107/api/v1/metrics
PROM_COLLECTOR_SERVER_HOST=0.0.0.0
PROM_COLLECTOR_SERVER_PORT=6107
PROM_COLLECTOR_SERVER_RELOAD=true
PROM_COLLECTOR_HOST_PORT=6107
PROMETHEUS_HOST_PORT=6118
NODE_EXPORTER_HOST_PORT=6119
DCGM_EXPORTER_HOST_PORT=6120
SEARXNG_HOST_PORT=6121

# --- Local tmux service names ---
CODE_TMUX_SESSION=rag-chatbot-code
BACKEND_TMUX_WINDOW=backend
FRONTEND_TMUX_WINDOW=frontend
PARSER_TMUX_WINDOW=parse-data
EMBEDDING_TMUX_WINDOW=embedding
PROMETHEUS_COLLECTOR_TMUX_WINDOW=prometheus-collector
FRONTEND_RUN_PORT=6103

# --- Optional external provider keys ---
VLLM_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# --- GeoIP auto download ---
MAXMIND_LICENSE_KEY=
GEOIP_AUTO_DOWNLOAD=true
GEOIP_STRICT=false
